# IF THE MICRO-SERVICE DOES NOT NEED ANY TEST-ONLY END-POINTS (ALWAYS PREFERRED) DELETE THIS FILE.

# !!!WARNING!!! This file MUST NOT be referenced in the "application.conf" file to avoid risk of rolling test routes in the production environment.
# If you need test routes when running tests in CI make sure that the profile for this micro-service (used by service-manager) defines this router as parameter.
# To do so add the following line to the micro-service profile: "-Dapplication.router=testOnlyDoNotUseInAppConf.Routes"
# To start the micro-service locally using the test routes run the following command: "sbt run -Dapplication.router=testOnlyDoNotUseInAppConf.Routes"

# Any test-only end-point should be defined here.
# !!!WARNING!!! Every route defined in this file MUST be prefixed with "/test-only/".
# Failing to follow this rule may result in test routes deployed in production.

# Add all the application routes to the prod.routes file
->            /                                                                                               prod.Routes
POST          /agent-registration/test-only/application                                                       uk.gov.hmrc.agentregistration.testOnly.controllers.TestApplicationController.upsertApplication
POST          /agent-registration/test-only/individual-provided-details                                       uk.gov.hmrc.agentregistration.testOnly.controllers.TestApplicationController.upsertIndividualProvidedDetails

GET           /agent-registration/test-only/individuals/by-agent-application-id/:agentApplicationId           uk.gov.hmrc.agentregistration.testOnly.controllers.TestApplicationController.findIndividuals(agentApplicationId: AgentApplicationId)
GET           /agent-registration/test-only/individuals/by-id/:individualProvidedDetailsId                    uk.gov.hmrc.agentregistration.testOnly.controllers.TestApplicationController.findIndividual(individualProvidedDetailsId: IndividualProvidedDetailsId)


POST          /                                                                                               uk.gov.hmrc.agentregistration.controllers.ApplicationController.upsertApplication

GET           /agent-registration/test-only/create-submitted-application                                      uk.gov.hmrc.agentregistration.testOnly.controllers.TestApplicationController.createTestApplication
GET           /agent-registration/test-only/recent-applications                                               uk.gov.hmrc.agentregistration.testOnly.controllers.TestApplicationController.recentApplications
GET           /agent-registration/test-only/application/by-agent-application-id/:agentApplicationId           uk.gov.hmrc.agentregistration.testOnly.controllers.TestApplicationController.findApplication(agentApplicationId: AgentApplicationId)


POST          /agent-registration/test-only/smu-viewer-individual                                             uk.gov.hmrc.agentregistration.testOnly.controllers.TestApplicationController.createTestSmuIndividual(scenario: Option[String] ?= None)
DELETE        /agent-registration/test-only/smu-viewer-individual/by-person-reference/:personReference        uk.gov.hmrc.agentregistration.testOnly.controllers.TestApplicationController.deleteTestSmuIndividual(personReference: PersonReference)
