{
  "apiId": "AR11",
  "apiTitle": "Create or Update Individual Provided Details for Individual",
  "description": "Creates or updates individual provided details for an individual. Requires Individual affinity group authentication.",
  "method": "PUT",
  "path": "/individual-provided-details/for-individual",
  "pathParameters": [],
  "queryParameters": [],
  "responses": [
    {
      "status": 200,
      "description": "Individual provided details created or updated"
    },
    {
      "status": 400,
      "description": "Bad request \u2013 invalid JSON body"
    },
    {
      "status": 401,
      "description": "Unauthorised"
    },
    {
      "status": 403,
      "description": "Forbidden \u2013 not Individual affinity group"
    }
  ],
  "authentication": {
    "required": true,
    "type": "Government Gateway",
    "affinityGroup": "Individual",
    "notes": "Only individuals can call this endpoint."
  },
  "audience": [
    "internal"
  ],
  "controller": "uk.gov.hmrc.agentregistration.controllers.providedetails.llp.IndividualProvidedDetailsController",
  "controllerMethod": "upsert",
  "services": [],
  "interactions": [
    {
      "step": 1,
      "actor": "Client",
      "action": "PUT /individual-provided-details/for-individual with IndividualProvidedDetails body",
      "target": "IndividualProvidedDetailsController"
    },
    {
      "step": 2,
      "actor": "IndividualProvidedDetailsController",
      "action": "individualAuthorised() \u2013 validate Individual affinity, retrieve internalId",
      "target": "HMRC Auth"
    },
    {
      "step": 3,
      "actor": "IndividualProvidedDetailsController",
      "action": "Parse IndividualProvidedDetails from body"
    },
    {
      "step": 4,
      "actor": "IndividualProvidedDetailsController",
      "action": "individualProvidedDetailsRepo.upsert(individualProvidedDetails)",
      "target": "MongoDB (individual)"
    },
    {
      "step": 5,
      "actor": "IndividualProvidedDetailsController",
      "action": "Return 200 Ok",
      "target": "Client"
    }
  ],
  "externalDependencies": [
    {
      "service": "HMRC Auth",
      "type": "HTTP/Auth",
      "purpose": "Authenticate caller (Individual)"
    }
  ],
  "databaseCollections": [
    {
      "name": "individual",
      "operation": "upsert",
      "filter": "_id == individualProvidedDetailsId"
    }
  ],
  "specialCases": [
    "Counterpart to AR07 but for Individuals (not Agents)",
    "ensureInternalUserId method exists in controller but is not called in this method",
    "Unique partial index on (internalUserId, agentApplicationId) prevents duplicate records"
  ],
  "metadata": {
    "lastUpdated": "2026-03-27",
    "gitCommitSha": "80d0452b1ed03094b02dbb594dcb24c1888fe8a4",
    "analysisVersion": "1.0"
  }
}