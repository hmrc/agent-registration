{
  "apiId": "AR10",
  "apiTitle": "Get Individual Provided Details by ID",
  "description": "Retrieves a single individual provided details record by its unique ID. Requires Agent affinity group.",
  "method": "GET",
  "path": "/individual-provided-details/by-id/{individualProvidedDetailsId}",
  "pathParameters": [
    {
      "name": "individualProvidedDetailsId",
      "type": "string",
      "required": true,
      "description": "Unique identifier of the individual provided details"
    }
  ],
  "queryParameters": [],
  "responses": [
    {
      "status": 200,
      "description": "Record found",
      "body": "IndividualProvidedDetails JSON"
    },
    {
      "status": 204,
      "description": "No record found"
    },
    {
      "status": 401,
      "description": "Unauthorised"
    },
    {
      "status": 403,
      "description": "Forbidden \u2013 unsupported credential role or HMRC-AS-AGENT active"
    }
  ],
  "authentication": {
    "required": true,
    "type": "Government Gateway",
    "affinityGroup": "Agent",
    "credentialRoles": [
      "User",
      "Admin"
    ]
  },
  "audience": [
    "internal"
  ],
  "controller": "uk.gov.hmrc.agentregistration.controllers.providedetails.llp.IndividualProvidedDetailsController",
  "controllerMethod": "findById",
  "services": [],
  "interactions": [
    {
      "step": 1,
      "actor": "Client",
      "action": "GET /individual-provided-details/by-id/{individualProvidedDetailsId}",
      "target": "IndividualProvidedDetailsController"
    },
    {
      "step": 2,
      "actor": "IndividualProvidedDetailsController",
      "action": "authorised() \u2013 validate Agent affinity",
      "target": "HMRC Auth"
    },
    {
      "step": 3,
      "actor": "IndividualProvidedDetailsController",
      "action": "individualProvidedDetailsRepo.findById(individualProvidedDetailsId)",
      "target": "MongoDB (individual)"
    },
    {
      "step": 4,
      "actor": "IndividualProvidedDetailsController",
      "action": "Return 200 Ok(Json.toJson(ipd)) or 204 NoContent",
      "target": "Client"
    }
  ],
  "externalDependencies": [
    {
      "service": "HMRC Auth",
      "type": "HTTP/Auth",
      "purpose": "Authenticate caller (Agent)"
    }
  ],
  "databaseCollections": [
    {
      "name": "individual",
      "operation": "findOne",
      "filter": "_id == individualProvidedDetailsId"
    }
  ],
  "specialCases": [
    "Returns 204 rather than 404 when not found"
  ],
  "metadata": {
    "lastUpdated": "2026-03-27",
    "gitCommitSha": "80d0452b1ed03094b02dbb594dcb24c1888fe8a4",
    "analysisVersion": "1.0"
  }
}