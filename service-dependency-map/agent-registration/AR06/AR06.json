{
  "apiId": "AR06",
  "apiTitle": "Get Application Business Partner Record by UTR",
  "description": "Retrieves a business partner record from DES for a given UTR, accessible by Individual affinity group users. Functionally equivalent to AR05 but uses Individual authentication.",
  "method": "GET",
  "path": "/application-business-partner-record/utr/{utr}",
  "pathParameters": [
    {
      "name": "utr",
      "type": "string",
      "required": true,
      "description": "Unique Taxpayer Reference"
    }
  ],
  "queryParameters": [],
  "responses": [
    {
      "status": 200,
      "description": "Business partner record found",
      "body": "BusinessPartnerRecordResponse JSON object"
    },
    {
      "status": 204,
      "description": "No business partner record found"
    },
    {
      "status": 400,
      "description": "Bad request \u2013 DES returned 400"
    },
    {
      "status": 401,
      "description": "Unauthorised"
    },
    {
      "status": 403,
      "description": "Forbidden \u2013 not Individual affinity group"
    },
    {
      "status": 500,
      "description": "Unexpected DES error"
    }
  ],
  "authentication": {
    "required": true,
    "type": "Government Gateway",
    "affinityGroup": "Individual",
    "notes": "Uses individualAuthorised action."
  },
  "audience": [
    "internal"
  ],
  "controller": "uk.gov.hmrc.agentregistration.controllers.BusinessPartnerRecordController",
  "controllerMethod": "getApplicationBusinessPartnerRecord",
  "services": [],
  "interactions": [
    {
      "step": 1,
      "actor": "Client",
      "action": "GET /application-business-partner-record/utr/{utr}",
      "target": "BusinessPartnerRecordController"
    },
    {
      "step": 2,
      "actor": "BusinessPartnerRecordController",
      "action": "individualAuthorised() \u2013 validate Individual affinity",
      "target": "HMRC Auth"
    },
    {
      "step": 3,
      "actor": "BusinessPartnerRecordController",
      "action": "businessPartnerRecordConnector.getBusinessPartnerRecord(utr)",
      "target": "BusinessPartnerRecordConnector"
    },
    {
      "step": 4,
      "actor": "BusinessPartnerRecordConnector",
      "action": "POST /registration/individual/utr/{utr} (isAnAgent=false, regime=ITSA, CorrelationId header)",
      "target": "DES"
    },
    {
      "step": 5,
      "actor": "BusinessPartnerRecordConnector",
      "action": "Parse DES JSON into BusinessPartnerRecordResponse"
    },
    {
      "step": 6,
      "actor": "BusinessPartnerRecordController",
      "action": "Return 200 Ok(bpr) or 204 NoContent",
      "target": "Client"
    }
  ],
  "externalDependencies": [
    {
      "service": "HMRC Auth",
      "type": "HTTP/Auth",
      "purpose": "Authenticate caller (Individual)"
    },
    {
      "service": "DES",
      "type": "HTTP/POST",
      "endpoint": "/registration/individual/utr/{utr}",
      "purpose": "Fetch business partner record by UTR",
      "authHeader": "Bearer {desAuthToken}",
      "customHeaders": [
        "Environment",
        "CorrelationId"
      ]
    }
  ],
  "databaseCollections": [],
  "specialCases": [
    "Identical DES call to AR05 but requires Individual affinity group",
    "DES 404 \u2192 204; DES 400 \u2192 BadRequestException; other errors \u2192 500"
  ],
  "metadata": {
    "lastUpdated": "2026-03-27",
    "gitCommitSha": "80d0452b1ed03094b02dbb594dcb24c1888fe8a4",
    "analysisVersion": "1.0"
  }
}