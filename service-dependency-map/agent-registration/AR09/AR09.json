{
  "apiId": "AR09",
  "apiTitle": "Get Individual Provided Details for Matching with Application",
  "description": "Retrieves all individual provided details for a given application ID, for use in matching workflows. Requires Individual affinity group.",
  "method": "GET",
  "path": "/individual-provided-details/for-matching-application/{agentApplicationId}",
  "pathParameters": [
    {
      "name": "agentApplicationId",
      "type": "string",
      "required": true,
      "description": "The unique identifier of the agent application"
    }
  ],
  "queryParameters": [],
  "responses": [
    {
      "status": 200,
      "description": "List of individual provided details (may be empty)",
      "body": "Array of IndividualProvidedDetails JSON"
    },
    {
      "status": 401,
      "description": "Unauthorised"
    },
    {
      "status": 403,
      "description": "Forbidden \u2013 not Individual affinity group"
    }
  ],
  "authentication": {
    "required": true,
    "type": "Government Gateway",
    "affinityGroup": "Individual",
    "notes": "Designed for the individual matching journey."
  },
  "audience": [
    "internal"
  ],
  "controller": "uk.gov.hmrc.agentregistration.controllers.providedetails.llp.IndividualProvidedDetailsController",
  "controllerMethod": "findForMatchingWithApplication",
  "services": [],
  "interactions": [
    {
      "step": 1,
      "actor": "Client",
      "action": "GET /individual-provided-details/for-matching-application/{agentApplicationId}",
      "target": "IndividualProvidedDetailsController"
    },
    {
      "step": 2,
      "actor": "IndividualProvidedDetailsController",
      "action": "individualAuthorised() \u2013 validate Individual affinity",
      "target": "HMRC Auth"
    },
    {
      "step": 3,
      "actor": "IndividualProvidedDetailsController",
      "action": "individualProvidedDetailsRepo.findForApplication(agentApplicationId)",
      "target": "MongoDB (individual)"
    },
    {
      "step": 4,
      "actor": "IndividualProvidedDetailsController",
      "action": "Return 200 Ok(Json.toJson(list))",
      "target": "Client"
    }
  ],
  "externalDependencies": [
    {
      "service": "HMRC Auth",
      "type": "HTTP/Auth",
      "purpose": "Authenticate caller (Individual)"
    }
  ],
  "databaseCollections": [
    {
      "name": "individual",
      "operation": "find",
      "filter": "agentApplicationId == agentApplicationId"
    }
  ],
  "specialCases": [
    "Same repo query as AR08 but requires Individual auth",
    "Always returns 200 with array"
  ],
  "metadata": {
    "lastUpdated": "2026-03-27",
    "gitCommitSha": "80d0452b1ed03094b02dbb594dcb24c1888fe8a4",
    "analysisVersion": "1.0"
  }
}