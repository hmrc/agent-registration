{
  "apiId": "AR01",
  "apiTitle": "Get Agent Application by Internal User ID",
  "description": "Retrieves an agent application for the currently authenticated Government Gateway user by their internal user ID, as derived from the auth enrolments.",
  "method": "GET",
  "path": "/application",
  "pathParameters": [],
  "queryParameters": [],
  "responses": [
    {
      "status": 200,
      "description": "Agent application found",
      "body": "AgentApplication JSON object"
    },
    {
      "status": 204,
      "description": "No application found for the authenticated user"
    },
    {
      "status": 401,
      "description": "Unauthorised"
    },
    {
      "status": 403,
      "description": "Forbidden \u2013 unsupported credential role or HMRC-AS-AGENT enrolment already active"
    }
  ],
  "authentication": {
    "required": true,
    "type": "Government Gateway",
    "affinityGroup": "Agent",
    "credentialRoles": [
      "User",
      "Admin"
    ],
    "notes": "HMRC-AS-AGENT enrolment must NOT be activated. InternalId retrieved from auth."
  },
  "audience": [
    "internal"
  ],
  "controller": "uk.gov.hmrc.agentregistration.controllers.ApplicationController",
  "controllerMethod": "findByInternalUserId",
  "services": [],
  "interactions": [
    {
      "step": 1,
      "actor": "Client",
      "action": "GET /application",
      "target": "ApplicationController"
    },
    {
      "step": 2,
      "actor": "ApplicationController",
      "action": "authorised() \u2013 validate Agent affinity, credential role, enrolments",
      "target": "HMRC Auth"
    },
    {
      "step": 3,
      "actor": "ApplicationController",
      "action": "agentApplicationRepo.findByInternalUserId(request.internalUserId)",
      "target": "MongoDB (agent-application)"
    },
    {
      "step": 4,
      "actor": "ApplicationController",
      "action": "Return 200 Ok(agentApplication) or 204 NoContent",
      "target": "Client"
    }
  ],
  "externalDependencies": [
    {
      "service": "HMRC Auth",
      "type": "HTTP/Auth",
      "purpose": "Authenticate caller and retrieve internalId"
    }
  ],
  "databaseCollections": [
    {
      "name": "agent-application",
      "operation": "findOne",
      "filter": "internalUserId == request.internalUserId"
    }
  ],
  "specialCases": [
    "Returns 204 if no application exists rather than 404",
    "Rejects if HMRC-AS-AGENT enrolment is already activated",
    "Rejects Assistant credential role"
  ],
  "metadata": {
    "lastUpdated": "2026-03-27",
    "gitCommitSha": "80d0452b1ed03094b02dbb594dcb24c1888fe8a4",
    "analysisVersion": "1.0"
  }
}